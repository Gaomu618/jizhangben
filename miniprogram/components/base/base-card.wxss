.base-card {
  position: relative;
  border-radius: var(--card-radius);
  background: var(--card-bg);
  border: 2rpx solid var(--card-border);
  transition: border-color var(--t-fast) var(--ease-out), box-shadow var(--t-base) var(--ease-out), transform var(--t-base) var(--ease-out);
}

/* Variants */
.card-default  { /* 默认就是 default */ }
.card-bordered { border-color: var(--color-border); }
.card-dark {
  background: var(--color-bg-deep);
  color: var(--color-text-inverse);
  border: none;
  box-shadow: var(--shadow-lg);
}
.card-gradient {
  background: linear-gradient(135deg, var(--paper-50) 0%, var(--card-bg) 50%, var(--orange-50) 100%);
  border-color: var(--color-border-soft);
}

/* Padding */
.card-pad-sm { padding: 24rpx; }
.card-pad-md { padding: 32rpx; }
.card-pad-lg { padding: 48rpx; }

/* States */
.is-hoverable { cursor: pointer; }
.is-hoverable.is-hoverable-active { transform: translateY(-2rpx); box-shadow: var(--shadow-md); border-color: var(--muted-2); }
.is-selected { border-color: var(--color-action-accent); box-shadow: 0 0 0 6rpx rgba(217, 79, 30, 0.12); }
.is-disabled { opacity: 0.5; pointer-events: none; }

/* Dark 卡片里的文字反转色 */
.card-dark .text-muted,
.card-dark .text-secondary { color: rgba(253, 251, 246, 0.55); }
.card-dark .eyebrow { color: rgba(253, 251, 246, 0.55); }
