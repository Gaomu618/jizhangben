.base-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 96rpx 48rpx;
  color: var(--color-text-muted);
}
.empty-icon { color: var(--muted-2); margin-bottom: 32rpx; opacity: 0.7; }
.empty-title { font-size: 36rpx; font-weight: 500; color: var(--color-text-primary); margin-bottom: 12rpx; }
.empty-message { max-width: 720rpx; line-height: 1.6; margin-bottom: 32rpx; }
.empty-cta { margin-top: 16rpx; }
