<view class="empty-state motion-fade-in" wx:if="{{state}}">
  <view wx:if="{{state.icon}}" class="empty-icon">{{state.icon}}</view>
  <view class="empty-title">{{state.title}}</view>
  <view wx:if="{{state.message}}" class="empty-message">{{state.message}}</view>
  <view wx:if="{{state.cta}}" class="empty-cta">
    <base-button
      variant="primary"
      size="sm"
      bind:click="onCta"
    >{{state.cta.text}}</base-button>
  </view>
</view>
