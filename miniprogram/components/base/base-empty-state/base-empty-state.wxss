.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 48rpx;
  text-align: center;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.7;
}
.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary, #0f172a);
  font-family: var(--font-display, serif);
  margin-bottom: 12rpx;
}
.empty-message {
  font-size: 26rpx;
  color: var(--color-text-muted, #9a9081);
  line-height: 1.5;
  max-width: 480rpx;
}
.empty-cta {
  margin-top: 32rpx;
}
