/* =====================================================================
   Motion — 动画 / 过渡工具类
   微信小程序用 wx.createAnimation 在 js 里驱动更稳，CSS transition 只用于
   颜色/边框等简单过渡。复杂动效用 animation 属性。
   ===================================================================== */

/* 全局过渡时长变量已在 tokens.wxss 定义 */
.fade-in {
  animation: fadeIn var(--t-base) var(--ease-out) both;
}
.slide-up {
  animation: slideUp var(--t-slow) var(--ease-out) both;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes slideUp {
  from { opacity: 0; transform: translateY(16rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* 数字滚动入场（统计页用） */
@keyframes numIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
.num-in { animation: numIn var(--t-slow) var(--ease-out) both; }

/* 按下反馈 */
.tap-active:active {
  opacity: 0.7;
  transform: scale(0.98);
  transition: all var(--t-fast) var(--ease-out);
}
