/* =====================================================================
   Typography — 字号 / 排版工具类
   从 frontend/src/typography.css 翻译。
   微信小程序不直接支持 clamp()，所以用阶梯写死。
   ===================================================================== */

.display {
  font-family: var(--font-display);
  font-weight: 500;
  letter-spacing: -0.01em;
  color: var(--color-text-primary);
}
.display em,
.display i {
  font-style: italic;
  color: var(--color-action-accent);
  font-weight: 700;
}

.numeric {
  font-family: var(--font-num);
  letter-spacing: -0.02em;
  font-feature-settings: 'tnum' 1, 'cv11' 1;
}

/* 字号阶梯（替代 clamp 流体） */
.h-hero    { font-family: var(--font-display); font-size: 96rpx; line-height: 1.05; font-weight: 500; letter-spacing: -0.025em; }
.h-page    { font-family: var(--font-display); font-size: 72rpx; line-height: 1.1;  font-weight: 500; letter-spacing: -0.02em; }
.h-section { font-family: var(--font-display); font-size: 56rpx; line-height: 1.2;  font-weight: 500; }
.h-card    { font-family: var(--font-display); font-size: 44rpx; line-height: 1.3;  font-weight: 500; }
.h-list    { font-size: 32rpx; font-weight: 600; }

.body-lg  { font-size: 32rpx; line-height: 1.6; }
.body     { font-size: 29rpx; line-height: 1.6; }
.body-sm  { font-size: 26rpx; line-height: 1.5; }
.micro    { font-size: 22rpx; line-height: 1.4; letter-spacing: 0.02em; }

/* 数字尾数小一号（规范：装饰性元素） */
.num-tail { font-size: 0.62em; opacity: 0.55; }
.num-sign { font-size: 0.78em; margin-right: 4rpx; }

/* Eyebrow 标签：NO.0X · 英文 · 中文 */
.eyebrow {
  font-family: var(--font-num);
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.14em;
  color: var(--color-text-muted);
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
}
.eyebrow::before {
  content: '';
  width: 36rpx;
  height: 2rpx;
  background: currentColor;
  opacity: 0.5;
}
.eyebrow-accent { color: var(--color-action-accent); }
.eyebrow-ink    { color: var(--color-text-primary); }
