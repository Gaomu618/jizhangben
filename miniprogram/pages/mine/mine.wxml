<view class="page app-bg">
  <view class="deco-glow-tr"></view>

  <!-- 用户卡片（dark variant） - #3 入场淡入 -->
  <base-card variant="dark" padding="lg" custom-class="user-card motion-slide-down">
    <view class="user" bindtap="onEditProfile">
      <view class="avatar">
        <!-- 优先级：微信头像 URL → 首字母（默认） -->
        <image wx:if="{{avatarUrl}}" class="avatar-image" src="{{avatarUrl}}" mode="aspectFill" binderror="onAvatarError"></image>
        <text wx:else class="avatar-initial">{{avatarInitial}}</text>
      </view>
      <view class="user-meta">
        <view class="user-name display">{{displayName}}</view>
        <view class="micro text-inverse" style="opacity: 0.55;">{{displaySubtext}}</view>
      </view>
      <text class="user-edit text-inverse">编辑 ›</text>
    </view>
  </base-card>

  <!-- 菜单列表 - #3 滑入 -->
  <view class="section motion-slide-up motion-slide-up-base">
    <view class="eyebrow section-title">账户</view>
    <view class="menu card card-pad-md">
      <view class="menu-row" bindtap="onEditProfile">
        <text class="body">编辑资料</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-row" bindtap="onOpenTrash">
        <text class="body">回收站</text>
        <view class="menu-row-right">
          <view wx:if="{{trashCount > 0}}" class="badge">{{trashCount > 99 ? '99+' : trashCount}}</view>
          <text class="menu-arrow">›</text>
        </view>
      </view>
      <view class="menu-row" bindtap="onOpenBudget">
        <text class="body">预算管理</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-row" bindtap="onImport">
        <text class="body">导入账单</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-row" bindtap="onExport">
        <text class="body">导出账单</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-row" bindtap="onAbout">
        <text class="body">关于本应用</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-row" bindtap="onClearCache">
        <text class="body">清除缓存</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section motion-slide-up motion-slide-up-base">
    <view class="eyebrow section-title">登录</view>
    <view class="menu card card-pad-md">
      <view class="menu-row danger" bindtap="onLogout">
        <text class="body">退出登录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="footer micro text-muted">个人记账 · v0.2.0</view>
  <view class="tabbar-safe"></view>
</view>
