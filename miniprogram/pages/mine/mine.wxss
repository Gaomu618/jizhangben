.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 0;
  position: relative;
  overflow: hidden;
}

/* ============== User Card ============== */
.user-card { position: relative; z-index: 1; padding: 48rpx 40rpx; }
.user { display: flex; align-items: center; gap: 32rpx; }
.avatar {
  width: 112rpx; height: 112rpx;
  border-radius: 50%;
  background: var(--orange-500);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  overflow: hidden;  /* 关键：圆角裁掉超出部分，否则方图会从圆框里漏出来 */
  box-shadow: 0 8rpx 24rpx rgba(217, 79, 30, 0.35);
}
.avatar-initial { color: var(--color-text-inverse); font-size: 56rpx; font-weight: 600; font-family: var(--font-num); }
.avatar-emoji { font-size: 64rpx; line-height: 1; }
/* image 默认有宽高 320x240，必须显式撑满容器才走 aspectFill 裁切 */
.avatar-image { width: 100%; height: 100%; display: block; }
.user-meta { display: flex; flex-direction: column; gap: 8rpx; flex: 1; min-width: 0; }
.user-name { color: var(--color-text-inverse); font-size: 40rpx; }
.user-edit {
  font-size: 26rpx;
  opacity: 0.7;
  padding: 8rpx 0 8rpx 16rpx;
  flex-shrink: 0;
}

/* ============== Section ============== */
.section { margin-top: 48rpx; position: relative; z-index: 1; }
.section-title { display: block; margin-bottom: 16rpx; padding-left: 8rpx; }

.menu { padding: 0 !important; }
.menu-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 2rpx solid var(--color-border-soft);
}
.menu-row:last-child { border-bottom: none; }
.menu-row.danger .body { color: var(--color-feedback-negative); }
.menu-arrow { color: var(--muted-2); font-size: 36rpx; }
.menu-row-right { display: flex; align-items: center; gap: 16rpx; }
.badge {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 12rpx;
  border-radius: 18rpx;
  background: var(--color-feedback-negative);
  color: #fff;
  font-size: 22rpx;
  line-height: 36rpx;
  text-align: center;
  font-weight: 600;
  font-family: var(--font-num);
}

.footer { text-align: center; margin-top: 64rpx; }
.tabbar-safe { height: 180rpx; }
