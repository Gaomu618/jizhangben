.container {
  min-height: 100vh;
  background: #f5f5f5;
}
.user-info {
  background: #fff;
  padding: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #07c160;
  color: #fff;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}
.username {
  font-size: 32rpx;
  color: #333;
}
.menu-list {
  margin-top: 20rpx;
  background: #fff;
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.menu-item text:first-child {
  font-size: 28rpx;
  color: #333;
}
.arrow {
  color: #999;
}