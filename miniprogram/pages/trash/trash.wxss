.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 0;
  position: relative;
  overflow: hidden;
}

.filters { margin-bottom: 24rpx; position: relative; z-index: 1; }
.filter-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}
.filter-cell { flex: 1; }
.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: var(--paper-200);
  border-radius: var(--input-radius);
  font-size: 26rpx;
}
.filter-label { color: var(--color-text-muted); font-size: 24rpx; }
.picker-val { color: var(--color-text-primary); }
.picker-val.text-muted { color: var(--color-text-muted); }
.filter-dash { color: var(--color-text-muted); }
.filter-clear {
  padding: 16rpx 32rpx;
  background: var(--paper-200);
  border-radius: var(--input-radius);
  font-size: 24rpx;
  color: var(--color-action-accent);
  font-weight: 500;
}

.action-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}
.action-bar > view { flex: 1; }

.section { position: relative; z-index: 1; }

.trash-item { margin-bottom: 16rpx; transition: transform var(--t-fast) var(--ease-out); }
.trash-item-hover { transform: translateY(-2rpx); box-shadow: var(--shadow-sm); }

.trash-head { align-items: center; gap: 16rpx; }
.trash-left { flex: 1; gap: 4rpx; min-width: 0; }
.trash-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.trash-emoji { font-size: 32rpx; }
.trash-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.trash-detail {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid var(--color-border-soft);
}
.trash-detail-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
}
.text-muted { color: var(--color-text-muted); }
.text-positive { color: var(--color-feedback-positive); }
.text-expense { color: var(--color-feedback-negative); }
.numeric { font-family: var(--font-num); }

.tabbar-safe { height: 180rpx; }
