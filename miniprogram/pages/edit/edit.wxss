/* 复用 add 页面样式（基本一致） */
.page {
  min-height: 100vh;
  padding: 32rpx;
  position: relative;
  overflow: hidden;
}
.type-bar {
  display: flex; gap: 16rpx; background: var(--paper-200);
  padding: 8rpx; border-radius: 999px; margin-bottom: 32rpx;
  position: relative; z-index: 1;
}
.type-pill {
  flex: 1; text-align: center; padding: 20rpx 0; border-radius: 999px;
  font-size: 28rpx; font-weight: 600; color: var(--color-text-secondary);
  transition: all var(--t-fast) var(--ease-out);
}
.type-pill.is-active { background: var(--card-bg); color: var(--color-text-primary); box-shadow: var(--shadow-sm); }

.amount-card { display: flex; flex-direction: column; gap: 16rpx; padding: 40rpx; position: relative; z-index: 1; }
.amount-row { display: flex; align-items: baseline; gap: 12rpx; }
.amount-sign { font-size: 56rpx; font-weight: 500; color: var(--ink-900); font-family: var(--font-num); }
.amount-input { flex: 1; font-size: 96rpx; font-weight: 500; color: var(--ink-900); letter-spacing: -0.025em; line-height: 1.05; height: 112rpx; }
.amount-placeholder { color: var(--muted-2); }

.section { margin-top: 40rpx; position: relative; z-index: 1; }
.section-title { display: block; margin-bottom: 16rpx; padding-left: 8rpx; }

.cat-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.cat-chip { padding: 16rpx 32rpx; background: var(--paper-200); border-radius: 999px; font-size: 28rpx; font-weight: 500; color: var(--color-text-primary); transition: all var(--t-fast) var(--ease-out); }
.cat-chip.is-active { background: var(--ink-900); color: var(--color-text-inverse); box-shadow: var(--shadow-sm); }

.picker-row { display: flex; align-items: center; justify-content: space-between; }
.picker-arrow { color: var(--muted-2); font-size: 40rpx; }

.submit-bar { margin-top: 64rpx; position: relative; z-index: 1; }
.delete-link {
  text-align: center;
  margin-top: 32rpx;
  font-size: 26rpx;
  color: var(--color-feedback-negative);
  text-decoration: underline;
  text-underline-offset: 8rpx;
}

.tabbar-safe { height: 180rpx; }
