.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 0;
  position: relative;
  overflow: hidden;
}

.section { margin-bottom: 24rpx; position: relative; z-index: 1; }

/* ============== Range Selector ============== */
.range-row {
  white-space: nowrap;
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 4rpx 0;
}
.range-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  background: var(--paper-200);
  border-radius: 999px;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  transition: all var(--t-fast) var(--ease-out);
}
.range-chip.active {
  background: var(--color-action-accent);
  color: #fff;
  font-weight: 600;
}
.custom-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
}
.custom-picker { flex: 1; }
.picker-cell {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 16rpx 20rpx;
  background: var(--paper-200);
  border-radius: var(--input-radius);
}
.picker-val { font-size: 26rpx; }
.filter-dash { color: var(--color-text-muted); }

/* ============== Hero 1+3 ============== */
.stats-hero-row {
  display: flex;
  gap: 16rpx;
}
.stats-hero-main {
  flex: 1.2;
  min-height: 280rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 32rpx 32rpx !important;
}
.eyebrow-ink { color: var(--color-text-inverse); opacity: 0.55; }
.hero-value {
  font-size: 80rpx;
  font-weight: 600;
  line-height: 1;
  letter-spacing: -0.02em;
  font-family: var(--font-num);
  margin: 12rpx 0;
}
.hero-delta {
  font-size: 24rpx;
  font-weight: 500;
  font-family: var(--font-num);
}

.stats-hero-side {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.stats-mini-card {
  flex: 1;
  padding: 16rpx 20rpx !important;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.mini-value {
  font-size: 32rpx;
  font-weight: 600;
  font-family: var(--font-num);
  color: var(--color-text-primary);
}
.mini-meta { font-size: 20rpx; }
.text-accent { color: var(--color-action-accent); }
.text-positive { color: var(--color-feedback-positive); }
.text-muted { color: var(--color-text-muted); }

/* ============== Card Head / Legend ============== */
.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.legend { display: flex; align-items: center; gap: 8rpx; }
.legend-cell {
  width: 24rpx;
  height: 24rpx;
  border-radius: 4rpx;
  border: 1rpx solid var(--color-border-soft);
}
.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

/* ============== Canvas ============== */
.heatmap-canvas { width: 100%; height: 360rpx; }
.chart-canvas { width: 100%; height: 400rpx; }
.chart-canvas-sm { width: 100%; height: 520rpx; }
.chart-canvas-lg { width: 100%; height: 480rpx; }
/* 饼图专用：缩小高度，配合"左饼图 + 右图例"横向布局 */
.chart-canvas-pie { width: 100%; height: 320rpx; }

/* ============== Pie Block（收入/支出同卡） ============== */
.pie-block { padding: 8rpx 0; }
.pie-divider {
  height: 2rpx;
  background: var(--color-border-soft);
  margin: 8rpx 0;
}
.empty-msg { text-align: center; padding: 60rpx 0; }

/* ============== Pie Row 1+1 ============== */
.stats-pie-row {
  display: flex;
  gap: 16rpx;
}
.stats-pie-card { flex: 1; padding: 24rpx !important; }

/* ============== Budget ============== */
.budget-row {
  display: grid;
  grid-template-columns: 80rpx 1fr auto;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}
.budget-cat { font-size: 24rpx; color: var(--color-text-secondary); }
.budget-bar {
  height: 8rpx;
  background: var(--paper-200);
  border-radius: 4rpx;
  overflow: hidden;
}
.budget-bar-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width var(--t-slow) var(--ease-out);
}
.budget-amount {
  font-size: 22rpx;
  font-weight: 600;
  text-align: right;
  font-family: var(--font-num);
}
.muted-sm { color: var(--color-text-muted); font-weight: 400; }
.text-expense { color: var(--color-feedback-negative); }

/* ============== Top 5 ============== */
.top-list { display: flex; flex-direction: column; gap: 12rpx; margin-top: 16rpx; }
.top-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: var(--paper-100);
  border-radius: var(--input-radius);
}
.top-rank {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  background: var(--paper-200);
  color: var(--color-text-muted);
  font-family: var(--font-num);
  flex-shrink: 0;
}
.top-item.gold .top-rank { background: #f5c842; color: #5a3e00; }
.top-item.silver .top-rank { background: #d4d4d8; color: #27272a; }
.top-item.bronze .top-rank { background: #d99a6a; color: #4a2510; }
.top-emoji { font-size: 32rpx; flex-shrink: 0; }
.top-info { flex: 1; min-width: 0; gap: 2rpx; }
.top-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.top-meta { font-size: 20rpx; }
.top-amount { font-size: 28rpx; font-weight: 600; flex-shrink: 0; }

/* ============== Modal ============== */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 64rpx 48rpx;
}
.modal-card {
  background: var(--card-bg);
  border-radius: var(--card-radius);
  padding: 32rpx;
  width: 100%;
  max-width: 600rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  box-shadow: var(--shadow-lg);
}
.modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--color-border-soft);
}
.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  font-family: var(--font-display);
  color: var(--color-text-primary);
}
.modal-close {
  font-size: 48rpx;
  line-height: 1;
  color: var(--color-text-muted);
  padding: 0 12rpx;
}
.modal-loading, .modal-empty {
  text-align: center;
  padding: 60rpx 0;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow-y: auto;
  max-height: 60vh;
}
.detail-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 12rpx;
  border-bottom: 2rpx solid var(--color-border-soft);
}
.detail-item:last-child { border-bottom: none; }
.detail-emoji { font-size: 32rpx; }
.detail-info { flex: 1; min-width: 0; gap: 2rpx; }
.detail-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.detail-meta { font-size: 20rpx; }
.detail-amount {
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.col { display: flex; flex-direction: column; }
.tabbar-safe { height: 180rpx; }
