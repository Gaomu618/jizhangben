.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}
.header {
  background: #fff;
  padding: 30rpx;
}
.month-selector {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 20rpx;
}
.month-selector text {
  padding: 0 30rpx;
  font-size: 32rpx;
}
.stats {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}
.stat-item {
  text-align: center;
}
.label {
  font-size: 24rpx;
  color: #999;
}
.income {
  color: #07c160;
  font-size: 36rpx;
  font-weight: bold;
}
.expense {
  color: #fa5151;
  font-size: 36rpx;
  font-weight: bold;
}
.bill-list {
  margin-top: 20rpx;
  background: #fff;
}
.bill-item {
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}
.bill-left {
  flex: 1;
}
.bill-category {
  font-size: 32rpx;
  color: #333;
}
.bill-note {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}
.bill-right {
  text-align: right;
}
.bill-amount {
  font-size: 36rpx;
  font-weight: bold;
}
.bill-date {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 10rpx;
}
.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
}
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid #eee;
}
.nav-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
}
.add-btn {
  background: #07c160;
  color: #fff;
  border-radius: 40rpx;
  padding: 10rpx 40rpx;
}