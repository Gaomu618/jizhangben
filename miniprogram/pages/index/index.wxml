<view class="container">
  <view class="header">
    <view class="month-selector">
      <text bindtap="prevMonth">&lt;</text>
      <text class="month-text">{{year}}年{{month}}月</text>
      <text bindtap="nextMonth">&gt;</text>
    </view>
    <view class="stats">
      <view class="stat-item">
        <text class="label">收入</text>
        <text class="income">+{{income}}</text>
      </view>
      <view class="stat-item">
        <text class="label">支出</text>
        <text class="expense">-{{expense}}</text>
      </view>
      <view class="stat-item">
        <text class="label">结余</text>
        <text class="{{balance >= 0 ? 'income' : 'expense'}}">{{balance >= 0 ? '+' : ''}}{{balance}}</text>
      </view>
    </view>
  </view>

  <view class="bill-list">
    <block wx:for="{{bills}}" wx:key="id">
      <view class="bill-item" bindtap="editBill" data-id="{{item.id}}">
        <view class="bill-left">
          <view class="bill-category">{{item.category}}</view>
          <view class="bill-note">{{item.note || ''}}</view>
        </view>
        <view class="bill-right">
          <text class="bill-amount {{item.type === 'income' ? 'income' : 'expense'}}">
            {{item.type === 'income' ? '+' : '-'}}{{item.amount}}
          </text>
          <text class="bill-date">{{item.date}}</text>
        </view>
      </view>
    </block>
    <view wx:if="{{bills.length === 0}}" class="empty">暂无记录</view>
  </view>

  <view class="bottom-bar">
    <navigator url="/pages/stats/stats" class="nav-item">统计</navigator>
    <navigator url="/pages/add/add" class="nav-item add-btn">+记账</navigator>
    <navigator url="/pages/mine/mine" class="nav-item">我的</navigator>
  </view>
</view>