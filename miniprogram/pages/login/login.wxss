/* ============================================
   Login Page — Phase 2 重做版
   品牌强化 + Logo + 信任标识 + 微动效
   ============================================ */

.login-page {
  min-height: 100vh;
  /* 微妙渐变背景：从米白到浅米 */
  background: linear-gradient(180deg, var(--paper-100) 0%, var(--paper-200) 100%);
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 64rpx 64rpx;
  overflow: hidden;
  /* 第二个光晕 (蓝/冷色) 跟 warm 暖色形成对角呼应 */
}

/* 让 deco-glow-bl 显示为冷色调（design/decoration.wxss 默认是暖色） */
.login-page .deco-glow-bl {
  background: radial-gradient(circle at 20% 80%, rgba(29, 58, 138, 0.08) 0%, transparent 60%);
}

/* ============== Hero 区 ============== */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-top: 64rpx;
  margin-bottom: auto;  /* 推动下方内容到屏幕底部 */
  z-index: 1;
}

/* 大 Logo 圆形 */
.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  /* 暖橙渐变 + 投影 */
  background: linear-gradient(135deg, var(--orange-500) 0%, #f59e0b 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 16rpx 48rpx rgba(217, 79, 30, 0.25),
    0 4rpx 12rpx rgba(217, 79, 30, 0.15),
    inset 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 32rpx;
  /* 轻微脉动呼吸感（持续动效） */
  animation: logo-breathe 3s ease-in-out infinite;
}

@keyframes logo-breathe {
  0%, 100% { transform: scale(1); }
  50%      { transform: scale(1.04); }
}

.logo-emoji {
  font-size: 84rpx;
  /* emoji 默认 baseline 偏下，向上提一点让视觉居中 */
  line-height: 1;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.15));
}

/* 主标 "个人记账" */
.h-page {
  font-size: 64rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: -0.02em;
  line-height: 1.2;
  color: var(--ink-900);
  font-family: var(--font-display);
}
.h-page em {
  font-style: normal;
  color: var(--color-action-accent);  /* "记账" 用橙色强调 */
}

/* 副标 */
.hero-sub {
  font-size: 28rpx;
  color: var(--color-text-muted);
  text-align: center;
  margin-top: 8rpx;
  letter-spacing: 0.02em;
}

/* ============== 信任标识 ============== */
.trust-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-top: 48rpx;
  margin-bottom: 24rpx;
  z-index: 1;
}
.trust-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.trust-icon {
  font-size: 28rpx;
  line-height: 1;
}
.trust-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}
.trust-divider {
  width: 2rpx;
  height: 24rpx;
  background: var(--color-border);
}

/* ============== 登录按钮区 ============== */
.login-section {
  width: 100%;
  max-width: 640rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 48rpx;
  z-index: 1;
}

.login-agreement {
  text-align: center;
  line-height: 1.6;
  padding: 0 16rpx;
}
.login-agreement .text-accent {
  color: var(--color-action-accent);
  font-weight: 500;
}