# 微信小程序凭证 — 从微信公众平台 https://mp.weixin.qq.com 后台获取
# 申请/查看路径：开发管理 → 开发设置 → 拉到"小程序 AppSecret"那一栏
WECHAT_APPID=your_appid_here
WECHAT_SECRET=your_secret_here

# Flask 环境：development（自动 reload）| testing | production（waitress）
FLASK_ENV=development

# 强随机密钥（生产前用 `python -c "import secrets; print(secrets.token_hex(32))"` 生成）
SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-in-production
# JWT 受众/签发者（一般不用改，跨服务时再自定义）
JWT_AUDIENCE=gerenjizhang-app
JWT_ISSUER=gerenjizhang

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=jizhangapp

# CORS 白名单（生产前必填）
# 例：https://your-app.com,*.weixin.qq.com
CORS_ALLOWED_ORIGINS=
